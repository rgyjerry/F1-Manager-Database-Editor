{
  "name": "f1-manager-database-editor",
  "productName": "F1 Manager Database Editor",
  "version": "3.5.10",
  "description": "Standalone macOS app for editing F1 Manager save files locally",
  "main": "electron/main.js",
  "scripts": {
    "build": "webpack",
    "build:desktop": "LOCAL_DESKTOP_APP=true NODE_ENV=production webpack",
    "start:desktop": "npm run build:desktop && electron .",
    "package:mac": "npm run build:desktop && electron-builder --mac dir --publish=never",
    "optimize:logos": "node scripts/optimize-team-logos.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rgyjerry/F1-Manager-Database-Editor.git"
  },
  "homepage": "https://github.com/rgyjerry/F1-Manager-Database-Editor#readme",
  "bugs": {
    "url": "https://github.com/rgyjerry/F1-Manager-Database-Editor/issues"
  },
  "author": "rgyjerry",
  "contributors": [
    "IUrreta <https://github.com/IUrreta>"
  ],
  "license": "LGPL-3.0-or-later",
  "dependencies": {
    "autoprefixer": "^10.4.20",
    "babel-loader": "^9.2.1",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.0",
    "buffer": "^6.0.3",
    "chart.js": "^4.4.0",
    "chartjs-plugin-annotation": "^3.0.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "copy-webpack-plugin": "^12.0.2",
    "crypto-browserify": "^3.12.1",
    "css-loader": "^7.1.2",
    "csv-parser": "^3.2.0",
    "dompurify": "^3.3.0",
    "file-saver": "^2.0.5",
    "html-webpack-plugin": "^5.6.3",
    "idb-keyval": "^6.2.2",
    "image-minimizer-webpack-plugin": "^4.1.3",
    "interactjs": "^1.10.17",
    "lz-string": "^1.5.0",
    "marked": "^7.0.3",
    "mini-css-extract-plugin": "^2.9.2",
    "pako": "^2.1.0",
    "playwright": "^1.57.0",
    "postcss-loader": "^8.1.1",
    "sass": "^1.84.0",
    "sass-loader": "^16.0.4",
    "sharp": "^0.33.5",
    "simple-git": "^3.19.1",
    "sql.js": "^1.13.0",
    "style-loader": "^4.0.0",
    "turndown": "^7.2.2",
    "webpack": "^5.97.1",
    "webpack-cli": "^5.1.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.rgyjerry.f1-manager-database-editor",
    "productName": "F1 Manager Database Editor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "LICENSE",
      "!node_modules/**/*"
    ],
    "npmRebuild": false,
    "mac": {
      "target": "dir",
      "category": "public.app-category.utilities",
      "identity": null
    },
    "asar": true
  }
}
